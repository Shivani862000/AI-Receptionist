NODE_ENV="development"
APP_NAME="AI Receptionist API"
PORT=4000
FRONTEND_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3001,http://localhost:3000"
BACKEND_BASE_URL="http://localhost:4000"
ENABLE_SWAGGER="true"
TRUST_PROXY="false"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_receptionist_poc?schema=public"

JWT_SECRET="super-secret-local-key"
JWT_EXPIRES_IN="1d"
JWT_ISSUER="ai-receptionist"
JWT_AUDIENCE="ai-receptionist-users"

RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
LOG_LEVEL="info"

UPLOAD_MAX_FILE_SIZE_MB=15
TEMP_FILE_TTL_HOURS=24
REALTIME_SESSION_TIMEOUT_MS=30000

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-preview"
AI_REQUEST_TIMEOUT_MS=15000

DEEPGRAM_API_KEY=""
DEEPGRAM_STT_MODEL="nova-3"
DEEPGRAM_TTS_MODEL="aura-asteria-en"
DEEPGRAM_REQUEST_TIMEOUT_MS=20000

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_WHATSAPP_NUMBER=""

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
